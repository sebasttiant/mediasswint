{
  "name": "mediasswint",
  "version": "0.0.0",
  "private": true,
  "description": "Software Interno Medias Elasticas - monorepo",
  "engines": {
    "node": ">=24.15.0 <25",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "lint": "pnpm --filter @mediasswint/web lint",
    "typecheck": "pnpm --filter @mediasswint/web typecheck",
    "build": "pnpm --filter @mediasswint/web build",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "infra:dev": "docker compose -f docker/docker-compose.dev.yml up -d --build",
    "infra:dev:down": "docker compose -f docker/docker-compose.dev.yml down",
    "infra:dev:logs": "docker compose -f docker/docker-compose.dev.yml logs -f",
    "infra:dev:ps": "docker compose -f docker/docker-compose.dev.yml ps"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
