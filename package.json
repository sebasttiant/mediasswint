{
  "name": "mediasswint",
  "version": "0.0.0",
  "private": true,
  "description": "Software Interno Medias Elasticas - monorepo",
  "engines": {
    "node": "24.15.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "pnpm --filter @mediasswint/web dev",
    "build": "pnpm --filter @mediasswint/web build",
    "start": "pnpm --filter @mediasswint/web start",
    "lint": "pnpm --filter @mediasswint/web lint",
    "infra:up": "docker compose -f docker/docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker/docker-compose.dev.yml down",
    "infra:logs": "docker compose -f docker/docker-compose.dev.yml logs -f",
    "infra:ps": "docker compose -f docker/docker-compose.dev.yml ps"
  }
}
