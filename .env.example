# ------------------------------------------------------------
# mediasswint - variables de entorno
#
# Uso:
#   cp .env.example .env              # para docker compose (raíz)
#   cp .env.example apps/web/.env     # para `pnpm dev` fuera de docker
#
# .env y .env.* están en .gitignore. NUNCA commitear credenciales reales.
# Para producción, los secretos se inyectan desde Coolify / el host.
# ------------------------------------------------------------

# --- App ---
NODE_ENV=development
APP_PORT=3000

# --- PostgreSQL 18 ---
# En docker compose (prod/dev) los valores se inyectan al contenedor postgres.
POSTGRES_USER=mediass
POSTGRES_PASSWORD=mediass
POSTGRES_DB=mediass
# Cuando se corre desde host (pnpm dev), apunta a localhost.
# Dentro de docker compose, la URL efectiva usa el hostname "postgres".
DATABASE_URL=postgresql://mediass:mediass@localhost:5432/mediass

# --- Redis 8.6 ---
REDIS_URL=redis://localhost:6379
