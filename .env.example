# ------------------------------------------------------------
# MEDIASSWINT - Dev environment variables
# Copy this file to .env and adjust values for local dev.
# .env is git-ignored. NEVER commit real credentials.
# ------------------------------------------------------------

# App
NODE_ENV=development
APP_PORT=3000

# PostgreSQL 18 (docker compose - dev)
DATABASE_URL=postgresql://mediass:mediass@localhost:5432/mediass

# Redis 8.6 (docker compose - dev)
REDIS_URL=redis://localhost:6379
