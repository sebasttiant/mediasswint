generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  isActive     Boolean    @default(true)
  fullName     String?
  role         UserRole   @default(STAFF)
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([isActive])
  @@index([role])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String
  diff       Json
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

enum UserRole {
  ADMIN
  STAFF
}

enum TemplateFieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
}

enum MeasurementSessionStatus {
  DRAFT
  COMPLETED
  VOID
}

enum PatientSex {
  FEMALE
  MALE
}

model Patient {
  id             String                @id @default(cuid())
  documentType   String?
  documentNumber String?
  fullName       String
  sex            PatientSex?
  birthDate      DateTime?
  phone          String?
  email          String?
  notes          String?
  sessions       MeasurementSession[]
  operations     CommercialOperation[]
  payments       PaymentMovement[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([documentType, documentNumber])
  @@index([fullName])
  @@index([documentNumber])
}

model MeasurementTemplate {
  id          String               @id @default(cuid())
  code        String?              @unique
  name        String
  version     Int                  @default(1)
  description String?
  isActive    Boolean              @default(true)
  sections    TemplateSection[]
  sessions    MeasurementSession[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([name, version])
  @@index([isActive])
}

model TemplateSection {
  id         String              @id @default(cuid())
  templateId String
  title      String
  sortOrder  Int                 @default(0)
  template   MeasurementTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fields     TemplateField[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([templateId, title])
  @@index([templateId, sortOrder])
}

model TemplateField {
  id         String             @id @default(cuid())
  sectionId  String
  key        String
  label      String
  fieldType  TemplateFieldType
  unit       String?
  isRequired Boolean            @default(false)
  sortOrder  Int                @default(0)
  minValue   Decimal?           @db.Decimal(10, 2)
  maxValue   Decimal?           @db.Decimal(10, 2)
  metadata   Json?
  section    TemplateSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  values     MeasurementValue[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([sectionId, key])
  @@index([sectionId, sortOrder])
}

model MeasurementSession {
  id               String                   @id @default(cuid())
  patientId        String
  templateId       String?
  status           MeasurementSessionStatus @default(DRAFT)
  measuredAt       DateTime                 @default(now())
  notes            String?
  diagnosis        String?
  garmentType      String?
  compressionClass String?
  templateSnapshot Json?
  productFlags     Json?
  metadata         Json?
  patient          Patient                  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  template         MeasurementTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  values           MeasurementValue[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([patientId, measuredAt])
  @@index([templateId])
  @@index([status])
}

model MeasurementValue {
  id           String             @id @default(cuid())
  sessionId    String
  fieldId      String
  valueText    String?
  valueNumber  Decimal?           @db.Decimal(10, 2)
  valueBoolean Boolean?
  session      MeasurementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  field        TemplateField      @relation(fields: [fieldId], references: [id], onDelete: Restrict)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([sessionId, fieldId])
  @@index([fieldId])
}

// Etapa D: Operaciones Comerciales

enum CommercialOperationStatus {
  PRESUPUESTO
  CONFIRMADO
  EN_PRODUCCION
  ENTREGADO
  CANCELADO
}

// Etapa F: Caja y Finanzas — payment ledger + cashbox.
//
// PaymentMovement is the source of truth for "Caja y Finanzas". Each new deposit
// creates ONE movement inside the same Serializable transaction that increments
// CommercialOperation.depositPaid (kept as a cached total so existing balances do
// not break). Legacy deposits made before this ledger existed are NOT backfilled:
// they have no trustworthy date/method, so they stay out of the daily cashbox.
//
// Two orthogonal dimensions are captured per movement:
//  - method (how the money came in)        → drives the cash vs. electronic split
//  - incomeType (Excel "1 Vez/R/MEFE/...")  → drives Total Abonos / Total Reclamados

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  BOLD
  TARJETA_DEBITO
  TARJETA_CREDITO
  OTRO
}

enum PaymentBank {
  BANCOLOMBIA
  NEQUI
  DAVIPLATA
  OTRO_BANCO
  OTRO
}

enum PaymentIncomeType {
  PRIMERA_VEZ
  R
  MEFE
  RECLAMADO_PRIMERA_VEZ
  RECLAMADO_R
}

model PaymentMovement {
  id          String              @id @default(cuid())
  operationId String
  patientId   String
  amount      Decimal             @db.Decimal(10, 2)
  method      PaymentMethod
  bank        PaymentBank?
  incomeType  PaymentIncomeType   @default(PRIMERA_VEZ)
  // SLICE 1: paidAt is always now() (the registration instant). The cashbox groups
  // by this day in the clinic timezone.
  // TODO (slice 2): allow an editable payment date so a deposit registered late can
  // be attributed to the day the money actually came in. When added, keep createdAt
  // as the immutable audit timestamp and let paidAt be user-editable.
  paidAt      DateTime            @default(now())
  note        String?
  operation   CommercialOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  patient     Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())

  @@index([paidAt])
  @@index([operationId])
  @@index([patientId])
}

// Manual cash outflow. Minimal by design for the first cashbox slice.
model Expense {
  id        String   @id @default(cuid())
  date      DateTime
  amount    Decimal  @db.Decimal(10, 2)
  concept   String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// "Real contado" — the physically counted cash for a given day. One row per day.
model DailyCashCount {
  id            String   @id @default(cuid())
  date         DateTime @unique @db.Date
  countedAmount Decimal  @db.Decimal(10, 2)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CommercialOperation {
  id            String                    @id @default(cuid())
  patientId     String
  status        CommercialOperationStatus @default(PRESUPUESTO)
  totalAmount   Decimal?                  @db.Decimal(10, 2)
  depositPaid   Decimal                   @default(0) @db.Decimal(10, 2)
  garmentType   String?
  notes         String?
  // Etapa E: order metadata v1 — additive, all nullable. No payment-method,
  // cashbox, claim or delivery semantics yet. orderNumber is intentionally NOT
  // unique (legacy Excel data has duplicates/repairs/historical rows).
  orderNumber   String?
  orderedAt     DateTime?
  productCode   String?
  productType   String?
  quantity      Int?                      @default(1)
  invoiceNumber String?
  invoiceDate   DateTime?
  discount      Decimal?                  @db.Decimal(10, 2)
  exitDate      DateTime?
  patient       Patient                   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments      PaymentMovement[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([patientId, createdAt(sort: Desc)])
  @@index([orderNumber])
}
